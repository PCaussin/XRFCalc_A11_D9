<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0-ios26.0</TargetFramework>
    <SupportedOSPlatformVersion>13.0</SupportedOSPlatformVersion>
    <Nullable>enable</Nullable>
    <CodesignKey>Apple Development: Created via API (F2SG848B57)</CodesignKey>
    <CodesignProvision>VS: com.IOSPCaussin.XRFCalcForIOS Development</CodesignProvision>
    <SignAssembly>False</SignAssembly>
    <AssemblyOriginatorKeyFile>C:\Users\pierr\OneDrive\Documents\documents personnels\my-release-key.keystore</AssemblyOriginatorKeyFile>
    <ProvisioningType>automatic</ProvisioningType>
    <AssemblyTitle>XRFCalcForIOS</AssemblyTitle>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
    <CodesignKey>iPhone Developer</CodesignKey>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
    <BuildIpa>True</BuildIpa>
    <IpaPackageName>XRFCalc</IpaPackageName>
    <MtouchDebug>True</MtouchDebug>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|AnyCPU'">
    <BuildIpa>True</BuildIpa>
    <IpaPackageName>XRFCalc</IpaPackageName>
    <MtouchDebug>True</MtouchDebug>
  </PropertyGroup>

  <PropertyGroup Condition="'$(TargetFramework)'=='net9.0-ios26.0'">
    <CodesignKey>Apple Development: Created via API (F2SG848B57)</CodesignKey>
    <CodesignProvision>VS: com.IOSPCaussin.XRFCalcForIOS Development</CodesignProvision>
  </PropertyGroup>

  <!-- Keep package references and project references -->
  <ItemGroup>
    <PackageReference Include="Avalonia.Controls.WebView" />
    <PackageReference Include="Avalonia.iOS" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\XRFCalc\XRFCalc.csproj" />
  </ItemGroup>

  <ItemGroup>
    <AvaloniaUILicenseKey Include="avln_off_key:v1::" />
  </ItemGroup>

  <!-- Asset catalog for app icons -->
  <ItemGroup>
    <!-- Add the entire asset catalog so the iOS toolchain packages the AppIcon asset -->
    <ImageAsset Include="Assets.xcassets\**\*" />
  </ItemGroup>
  <ItemGroup>
    <None Remove="iTunesArtwork" />
    <None Remove="iTunesArtwork%402x" />
  </ItemGroup>

  <!-- Keep launch screen as image asset (no CopyToOutputDirectory) -->
  <ItemGroup>
    <ImageAsset Include="Resources\LaunchScreen.xib" />
  </ItemGroup>
  <ItemGroup>
    <iTunesArtwork Include="iTunesArtwork" />
    <iTunesArtwork Include="iTunesArtwork@2x" />
  </ItemGroup>
</Project>